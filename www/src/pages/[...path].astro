---
import SiteDocument from "../layout/site-document.astro";
import { appRoutes } from "../routes";
import MachinesShowcase from "../theme-showcase/machines-showcase.astro";

export function getStaticPaths() {
	const appPaths = appRoutes
		.filter((route) => route.path !== "/")
		.map((route) => ({
			params: { path: route.path.slice(1) },
			props: { route },
		}));
	return [
		...appPaths,
		{ params: { path: "__theme" }, props: { route: undefined } },
	];
}

const { route } = Astro.props;
---
{route ? <SiteDocument route={route} /> : <MachinesShowcase />}
