{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Musi",
	"scopeName": "source.musi",
	"patterns": [
		{ "include": "#lexical-all" },
		{ "include": "#declaration-all" },
		{ "include": "#declaration-variants" },
		{ "include": "#signature-parameter-list" },
		{ "include": "#expression-all" },
		{ "include": "#type-annotation" },
		{ "include": "#where-clause" },
		{ "include": "#type-name" },
		{ "include": "#keyword-all" },
		{ "include": "#operator-all" },
		{ "include": "#identifier-all" },
		{ "include": "#punctuation-all" }
	],
	"repository": {
		"lexical-all": {
			"patterns": [
				{ "include": "#comment-all" },
				{ "include": "#attribute" },
				{ "include": "#string-all" },
				{ "include": "#number-all" }
			]
		},
		"comment-all": {
			"patterns": [
				{ "include": "#comment-doc-module-line" },
				{ "include": "#comment-doc-line" },
				{ "include": "#comment-doc-module-block" },
				{ "include": "#comment-doc-block" },
				{ "include": "#comment-line" },
				{ "include": "#comment-block" }
			]
		},
		"comment-doc-module-line": {
			"name": "comment.line.documentation.module.musi",
			"begin": "^\\s*--!",
			"end": "^(?!\\s*--!)",
			"beginCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
			"patterns": [ { "include": "#documentation-content" } ]
		},
		"comment-doc-line": {
			"name": "comment.line.documentation.musi",
			"begin": "^\\s*---",
			"end": "^(?!\\s*---)",
			"beginCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
			"patterns": [ { "include": "#documentation-content" } ]
		},
		"comment-doc-module-block": {
			"name": "comment.block.documentation.module.musi",
			"begin": "/-!",
			"end": "-/",
			"beginCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
			"patterns": [
				{ "include": "#documentation-content" },
				{ "include": "#comment-block" }
			]
		},
		"comment-doc-block": {
			"name": "comment.block.documentation.musi",
			"begin": "/--",
			"end": "-/",
			"beginCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.comment.documentation.musi" } },
			"patterns": [
				{ "include": "#documentation-content" },
				{ "include": "#comment-block" }
			]
		},
		"comment-line": {
			"name": "comment.line.double-dash.musi",
			"match": "--.*$"
		},
		"comment-block": {
			"name": "comment.block.musi",
			"begin": "/-(?![!-])",
			"end": "-/",
			"beginCaptures": { "0": { "name": "punctuation.definition.comment.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.comment.musi" } },
			"patterns": [ { "include": "#comment-all" } ]
		},
		"documentation-content": {
			"patterns": [
				{ "include": "#documentation-fenced-code" },
				{ "include": "#documentation-param-tag" },
				{ "include": "#documentation-type-tag" },
				{ "include": "#documentation-option-tag" },
				{ "include": "#documentation-see-tag" },
				{ "include": "#documentation-inline-link" },
				{ "include": "#documentation-code-tag" },
				{ "include": "#documentation-inline-code" },
				{ "include": "#documentation-known-tag" },
				{ "include": "#documentation-unknown-tag" },
				{ "include": "#documentation-url" },
				{ "include": "#documentation-definition-operator" }
			]
		},
		"documentation-tag-capture": {
			"name": "keyword.other.documentation.tag.musi",
			"match": "@[A-Za-z_][A-Za-z0-9_]*\\b"
		},
		"documentation-type-brace": {
			"name": "storage.type.documentation.musi",
			"match": "\\{[^}]+\\}"
		},
		"documentation-optional-name": {
			"name": "variable.parameter.optional.documentation.musi",
			"match": "\\[[A-Za-z_][A-Za-z0-9_]*(?:\\s*:=\\s*[^\\]]+)?\\]"
		},
		"documentation-param-name": {
			"name": "variable.parameter.documentation.musi",
			"match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?::=|\\{|\\[|$))"
		},
		"documentation-simple-name": {
			"name": "variable.parameter.documentation.musi",
			"match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?::=|$))"
		},
		"documentation-definition-operator": {
			"name": "punctuation.separator.definition.documentation.musi",
			"match": ":="
		},
		"documentation-link-target": {
			"name": "markup.underline.link.documentation.musi",
			"match": "[A-Za-z_][A-Za-z0-9_]*(?:#[A-Za-z_][A-Za-z0-9_]*)?(?:\\.[A-Za-z_][A-Za-z0-9_]*)*"
		},
		"documentation-link-pipe": {
			"name": "punctuation.separator.pipe.documentation.musi",
			"match": "\\|"
		},
		"documentation-link-label": {
			"name": "string.unquoted.label.documentation.musi",
			"match": "[^|}\\s][^|}]*"
		},
		"documentation-param-tag": {
			"name": "meta.documentation.param.musi",
			"begin": "@(param(?:eter)?|arg(?:ument)?|property|var)\\b",
			"end": "(?=\\s*(?:@|\\*/|$))",
			"beginCaptures": {
				"0": { "name": "keyword.other.documentation.tag.musi" },
				"1": { "name": "keyword.other.documentation.tag.musi" }
			},
			"patterns": [
				{ "include": "#punctuation-doc-bracket-begin" },
				{ "include": "#punctuation-doc-bracket-end" },
				{ "include": "#documentation-type-brace" },
				{ "include": "#documentation-optional-name" },
				{ "include": "#documentation-param-name" },
				{ "include": "#documentation-definition-operator" }
			]
		},
		"documentation-type-tag": {
			"name": "meta.documentation.type.musi",
			"begin": "@(type|template)\\b",
			"end": "(?=\\s*(?:@|\\*/|$))",
			"beginCaptures": {
				"0": { "name": "keyword.other.documentation.tag.musi" },
				"1": { "name": "keyword.other.documentation.tag.musi" }
			},
			"patterns": [
				{ "include": "#documentation-type-brace" },
				{ "include": "#documentation-definition-operator" },
				{ "include": "#documentation-simple-name" }
			]
		},
		"documentation-option-tag": {
			"name": "meta.documentation.option.musi",
			"begin": "@(default|optional)\\b",
			"end": "(?=\\s*(?:@|\\*/|$))",
			"beginCaptures": {
				"0": { "name": "keyword.other.documentation.tag.musi" },
				"1": { "name": "keyword.other.documentation.tag.musi" }
			},
			"patterns": [
				{ "include": "#documentation-optional-name" },
				{ "include": "#documentation-definition-operator" },
				{ "include": "#documentation-simple-name" }
			]
		},
		"documentation-see-tag": {
			"name": "meta.documentation.reference.musi",
			"begin": "@(see)\\b",
			"end": "(?=\\s*(?:@|\\*/|$))",
			"beginCaptures": {
				"0": { "name": "keyword.other.documentation.tag.musi" },
				"1": { "name": "keyword.other.documentation.tag.musi" }
			},
			"patterns": [
				{ "include": "#documentation-link-target" },
				{ "include": "#documentation-link-pipe" },
				{ "include": "#documentation-link-label" }
			]
		},
		"documentation-inline-link": {
			"name": "meta.documentation.reference.musi",
			"begin": "\\{@(?:link(?:plain)?|linkplain|see)\\b",
			"end": "\\}",
			"beginCaptures": { "0": { "name": "keyword.other.documentation.tag.musi" } },
			"patterns": [
				{ "include": "#documentation-link-target" },
				{ "include": "#documentation-link-pipe" },
				{ "include": "#documentation-link-label" }
			]
		},
		"documentation-code-tag": {
			"name": "meta.documentation.formatting.musi",
			"begin": "@(code|literal)\\b",
			"end": "(?=\\s*(?:@|\\*/|$))",
			"beginCaptures": {
				"0": { "name": "keyword.other.documentation.tag.musi" },
				"1": { "name": "keyword.other.documentation.tag.musi" }
			},
			"patterns": [
				{
					"name": "markup.inline.raw.documentation.musi",
					"match": "[^@]+"
				}
			]
		},
		"documentation-inline-code": {
			"name": "meta.documentation.formatting.musi",
			"begin": "\\{@(?:code|literal)\\b",
			"end": "\\}",
			"beginCaptures": { "0": { "name": "keyword.other.documentation.tag.musi" } },
			"patterns": [
				{
					"name": "markup.inline.raw.documentation.musi",
					"match": "[^}]+"
				}
			]
		},
		"documentation-known-tag": {
			"name": "keyword.other.documentation.tag.musi",
			"match": "@(returns?|deprecated|example|remarks?|summary|since|version)\\b"
		},
		"documentation-unknown-tag": {
			"include": "#documentation-tag-capture"
		},
		"documentation-url": {
			"name": "markup.underline.link.documentation.musi",
			"match": "https?://[^\\s)]+"
		},
		"punctuation-doc-bracket-begin": {
			"name": "punctuation.section.brackets.begin.documentation.musi",
			"match": "\\["
		},
		"punctuation-doc-bracket-end": {
			"name": "punctuation.section.brackets.end.documentation.musi",
			"match": "\\]"
		},
		"attribute": {
			"name": "meta.attribute.musi",
			"begin": "@(?=[A-Za-z_])",
			"end": "(?=\\s|$|[;,\\]}\\)])",
			"beginCaptures": { "0": { "name": "punctuation.definition.attribute.musi" } },
			"patterns": [
				{ "include": "#attribute-name" },
				{ "include": "#attribute-arguments" }
			]
		},
		"attribute-name": {
			"name": "entity.name.tag.attribute.musi",
			"match": "[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*"
		},
		"attribute-arguments": {
			"name": "meta.attribute.arguments.musi",
			"begin": "\\(",
			"end": "\\)",
			"beginCaptures": { "0": { "name": "punctuation.section.parens.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.section.parens.end.musi" } },
			"patterns": [ { "include": "$self" } ]
		},
		"string-all": {
			"patterns": [
				{ "include": "#string-template" },
				{ "include": "#string-double" },
				{ "include": "#string-rune" }
			]
		},
		"string-template": {
			"name": "string.template.musi",
			"begin": "`",
			"end": "`",
			"beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
			"patterns": [
				{
					"name": "meta.embedded.expression.musi",
					"begin": "\\$\\{",
					"end": "\\}",
					"contentName": "source.musi.embedded",
					"beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.musi" } },
					"endCaptures": { "0": { "name": "punctuation.section.embedded.end.musi" } },
					"patterns": [ { "include": "$self" } ]
				},
				{ "include": "#string-escape" }
			]
		},
		"string-double": {
			"name": "string.quoted.double.musi",
			"begin": "\"",
			"end": "\"",
			"beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
			"patterns": [ { "include": "#string-escape" } ]
		},
		"string-rune": {
			"name": "constant.character.musi",
			"begin": "'",
			"end": "'",
			"beginCaptures": { "0": { "name": "punctuation.definition.string.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.definition.string.end.musi" } },
			"patterns": [ { "include": "#string-escape" } ]
		},
		"string-escape": {
			"name": "constant.character.escape.musi",
			"match": "\\\\."
		},
		"number-all": {
			"patterns": [
				{ "include": "#number-hex" },
				{ "include": "#number-octal" },
				{ "include": "#number-binary" },
				{ "include": "#number-float" },
				{ "include": "#number-decimal" }
			]
		},
		"number-hex": {
			"name": "constant.numeric.hex.musi",
			"match": "\\b0[xX][0-9a-fA-F](?:[0-9a-fA-F_]*[0-9a-fA-F])?\\b"
		},
		"number-octal": {
			"name": "constant.numeric.octal.musi",
			"match": "\\b0[oO][0-7](?:[0-7_]*[0-7])?\\b"
		},
		"number-binary": {
			"name": "constant.numeric.binary.musi",
			"match": "\\b0[bB][01](?:[01_]*[01])?\\b"
		},
		"number-float": {
			"name": "constant.numeric.float.musi",
			"match": "\\b[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?\\b|\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?\\b|\\b[0-9][0-9_]*(?:[eE][+-]?[0-9_]+)\\b"
		},
		"number-decimal": {
			"name": "constant.numeric.decimal.musi",
			"match": "\\b[0-9][0-9_]*\\b"
		},
		"declaration-all": {
			"patterns": [
				{ "include": "#declaration-fixity" },
				{ "include": "#declaration-native-function" },
				{ "include": "#declaration-let-dot-callable" },
				{ "include": "#declaration-let-function" },
				{ "include": "#declaration-let-value" },
				{ "include": "#declaration-let-type" },
				{ "include": "#declaration-type-form" },
				{ "include": "#declaration-given" },
				{ "include": "#declaration-law" },
				{ "include": "#declaration-member-function" },
				{ "include": "#declaration-type-parameters" }
			]
		},
		"declaration-fixity": {
			"name": "meta.declaration.fixity.musi",
			"match": "\\b(infixl|infixr|infix)\\b\\s+([0-9][0-9_]*)\\s*(\\((?:[*/+\\-%=<>]{1,})\\))",
			"captures": {
				"1": { "name": "keyword.declaration.fixity.musi" },
				"2": { "name": "constant.numeric.decimal.musi" },
				"3": { "name": "entity.name.function.operator.fixity.musi" }
			}
		},
		"declaration-native-function": {
			"name": "meta.declaration.native.musi",
			"match": "\\b(native)\\b(?:\\s+(\"[^\"]+\"))?\\s+(let)\\s+([a-z_][A-Za-z0-9_]*)",
			"captures": {
				"1": { "name": "storage.modifier.musi" },
				"2": { "name": "string.quoted.double.musi" },
				"3": { "name": "keyword.declaration.musi" },
				"4": { "name": "entity.name.function.musi" }
			}
		},
		"declaration-let-function": {
			"name": "meta.declaration.function.musi",
			"match": "\\b(let)\\b(?:\\s+(rec)\\b)?(?:\\s+(\\[[^\\]\\\\n]*\\]))?\\s+([a-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\[[^\\]\\\\n]*\\]\\s*)?\\()",
			"captures": {
				"1": { "name": "keyword.declaration.musi" },
				"2": { "name": "storage.modifier.musi" },
				"3": { "name": "meta.type.parameters.musi" },
				"4": { "name": "entity.name.function.musi" }
			}
		},
		"declaration-let-value": {
			"name": "meta.declaration.value.musi",
			"match": "\\b(let)\\b(?:\\s+(rec)\\b)?(?:\\s+(\\[[^\\]\\\\n]*\\]))?\\s+([a-z_][A-Za-z0-9_]*)\\b(?=\\s*(?::|:=))",
			"captures": {
				"1": { "name": "keyword.declaration.musi" },
				"2": { "name": "storage.modifier.musi" },
				"3": { "name": "meta.type.parameters.musi" },
				"4": { "name": "variable.other.definition.musi" }
			}
		},
		"declaration-let-type": {
			"name": "meta.declaration.type.musi",
			"match": "\\b(let)\\b(?:\\s+(rec)\\b)?(?:\\s+(\\[[^\\]\\\\n]*\\]))?\\s+([A-Z][A-Za-z0-9_]*)\\b(?=\\s*(?:\\[[^\\]\\\\n]*\\]\\s*)?:=\\s*(?:shape|data|effect|given)\\b)",
			"captures": {
				"1": { "name": "keyword.declaration.musi" },
				"2": { "name": "storage.modifier.musi" },
				"3": { "name": "meta.type.parameters.musi" },
				"4": { "name": "entity.name.type.musi" }
			}
		},
		"declaration-type-form": {
			"name": "meta.declaration.type.musi",
			"match": "\\b(shape|data|effect)\\s+([A-Z][A-Za-z0-9_]*)",
			"captures": {
				"1": { "name": "storage.type.musi" },
				"2": { "name": "entity.name.type.musi" }
			}
		},
		"declaration-given": {
			"name": "meta.declaration.given.musi",
			"match": "\\b(given)\\b",
			"captures": { "1": { "name": "keyword.declaration.musi" } }
		},
		"declaration-law": {
			"name": "meta.declaration.member.law.musi",
			"match": "\\b(law)\\b\\s+([a-z_][A-Za-z0-9_]*)",
			"captures": {
				"1": { "name": "keyword.declaration.musi" },
				"2": { "name": "entity.name.function.law.musi" }
			}
		},
		"declaration-member-function": {
			"name": "meta.declaration.member.function.musi",
			"match": "(^|[;{]\\s*)(?:let\\s+)?([a-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\[[^\\]\\\\n]*\\]\\s*)?\\([^)]*\\)\\s*(?::|:=|where\\b|require\\b))",
			"captures": { "2": { "name": "entity.name.function.musi" } }
		},
		"signature-parameter-list": {
			"name": "meta.parameters.musi",
			"begin": "\\((?=[^\\)\\n]*\\b(?:comptime\\s+)?(?:self|[a-z_][A-Za-z0-9_]*)\\s*:)",
			"end": "\\)",
			"beginCaptures": { "0": { "name": "punctuation.section.parens.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.section.parens.end.musi" } },
			"patterns": [
				{ "include": "#receiver-parameter" },
				{ "include": "#parameter-name" },
				{ "include": "#type-annotation" },
				{ "include": "#keyword-all" },
				{ "include": "#punctuation-all" }
			]
		},
		"declaration-type-parameters": {
			"patterns": [ { "include": "#type-parameter-list" } ]
		},
		"declaration-variants": {
			"patterns": [
				{ "include": "#declaration-variant-payload" },
				{ "include": "#declaration-variant-unit" }
			]
		},
		"declaration-variant-payload": {
			"name": "meta.declaration.variant.musi",
			"begin": "(\\|\\s*)([A-Z][A-Za-z0-9_]*)(\\s*)(\\()",
			"end": "(\\))",
			"beginCaptures": {
				"2": { "name": "variable.other.enummember.musi" },
				"4": { "name": "punctuation.section.parens.begin.musi" }
			},
			"endCaptures": { "1": { "name": "punctuation.section.parens.end.musi" } },
			"patterns": [
				{ "include": "#receiver-parameter" },
				{
					"name": "variable.parameter.musi",
					"match": "\\b[a-z_][A-Za-z0-9_]*\\b(?=\\s:)"
				},
				{ "include": "#type-expression" },
				{ "include": "#operator-all" },
				{ "include": "#punctuation-all" }
			]
		},
		"declaration-variant-unit": {
			"name": "meta.declaration.variant.musi",
			"match": "(\\|\\s*)([A-Z][A-Za-z0-9_]*)\\b(?=\\s*(?:\\||\\}|;|$))",
			"captures": { "2": { "name": "variable.other.enummember.musi" } }
		},
		"type-annotation": {
			"name": "meta.type.annotation.musi",
			"begin": "(:)(?![=?])\\s*",
			"end": "(?=\\s*(?:,|;|\\)|\\}|:=|=>|\\||if\\b|require\\b|where\\b))",
			"beginCaptures": { "1": { "name": "punctuation.separator.colon.musi" } },
			"patterns": [ { "include": "#type-expression" } ]
		},
		"type-expression": {
			"name": "meta.type.expression.musi",
			"patterns": [
				{ "include": "#type-group" },
				{ "include": "#type-record" },
				{ "include": "#type-argument-list" },
				{ "include": "#type-operator-all" },
				{ "include": "#type-variable" },
				{ "include": "#type-name" },
				{ "include": "#keyword-type-context" },
				{ "include": "#punctuation-type-context" }
			]
		},
		"type-group": {
			"name": "meta.type.group.musi",
			"begin": "\\(",
			"end": "\\)",
			"beginCaptures": { "0": { "name": "punctuation.section.parens.begin.musi" } },
			"endCaptures": { "0": { "name": "punctuation.section.parens.end.musi" } },
			"patterns": [ { "include": "#type-expression" } ]
		},
		"type-record": {
			"name": "meta.type.record.musi",
			"begin": "\\{",
