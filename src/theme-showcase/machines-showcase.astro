---
import "@musi-lang/machines/style.scss";
import { componentGroups } from "@musi-lang/machines";
import ActionCard from "@musi-lang/machines/astro/ActionCard.astro";
import Button from "@musi-lang/machines/astro/Button.astro";
import Card from "@musi-lang/machines/astro/Card.astro";
import CodeFrame from "@musi-lang/machines/astro/CodeFrame.astro";
import DataTable from "@musi-lang/machines/astro/DataTable.astro";
import Field from "@musi-lang/machines/astro/Field.astro";
import List from "@musi-lang/machines/astro/List.astro";
import Message from "@musi-lang/machines/astro/Message.astro";
import MeterBar from "@musi-lang/machines/astro/MeterBar.astro";
import NavTabs from "@musi-lang/machines/astro/NavTabs.astro";
import Panel from "@musi-lang/machines/astro/Panel.astro";
import Post from "@musi-lang/machines/astro/Post.astro";
import ProgressBar from "@musi-lang/machines/astro/ProgressBar.astro";
import Root from "@musi-lang/machines/astro/Root.astro";
import Section from "@musi-lang/machines/astro/Section.astro";
import Shell from "@musi-lang/machines/astro/Shell.astro";
import SidebarLayout from "@musi-lang/machines/astro/SidebarLayout.astro";
import Tile from "@musi-lang/machines/astro/Tile.astro";
import { MachinesWidgets } from "../theme-showcase/machines-widgets";

const tabs = [
	{ href: "/__theme", label: "Overview", active: true },
	{ href: "#__controls", label: "Controls" },
	{ href: "#__tabs", label: "Tabs" },
	{ href: "#__bars", label: "Bars" },
	{ href: "#__layout", label: "Layout" },
];

const importExample = `import "@musi-lang/machines/style.scss";
import Panel from "@musi-lang/machines/astro/Panel.astro";
import Button from "@musi-lang/machines/astro/Button.astro";`;
const buttonExample = `<Button>Primary</Button>
<Button variant="secondary">Secondary</Button>
<Button variant="hollow">Hollow</Button>
<Button variant="ghost">Ghost</Button>
<Button variant="danger">Danger</Button>`;
const codeTabsExample = `<CodeTabs
  label="Install commands"
  tabs={[{ id: "macos", label: "macOS / Linux", language: "sh", code }]}
/>`;
const messageExample = `<Message title="Message box" mark="※">
  <p>Use for hints, warnings, and status copy.</p>
</Message>`;
const barsExample = `<ProgressBar label="Build progress" value={72} showValue />
<MeterBar label="Cache health" value={82} high={75} optimum={90} showValue />
<List variant="check">
  <li>Native lists</li>
  <li>Themed bars</li>
</List>`;
const customThemeStyle = `
	--mx-bg: #f6efe3;
	--mx-surface: #fffaf1;
	--mx-surface-2: #efe4d1;
	--mx-surface-3: #e4f0ed;
	--mx-header: #73503f;
	--mx-header-2: #b98d70;
	--mx-accent: #8a5f4f;
	--mx-accent-2: #22788a;
`;
const colorTokens = [
	["Base", ["--mx-bg", "--mx-surface", "--mx-surface-2", "--mx-surface-3"]],
	[
		"Chrome",
		[
			"--mx-rail",
			"--mx-header",
			"--mx-header-2",
			"--mx-subheader",
			"--mx-subheader-2",
		],
	],
	["Borders", ["--mx-border", "--mx-border-strong", "--mx-border-soft"]],
	["Text", ["--mx-text", "--mx-muted", "--mx-link", "--mx-link-hover"]],
	[
		"Signals",
		[
			"--mx-accent",
			"--mx-accent-2",
			"--mx-good",
			"--mx-warn",
			"--mx-danger",
			"--mx-focus",
		],
	],
] as const;
const signalTokens = [
	"--mx-accent-2",
	"--mx-good",
	"--mx-warn",
	"--mx-danger",
	"--mx-focus",
] as const;
const colorVisionPreviews = [
	{ id: "normal", label: "Default vision" },
	{ id: "protanopia", label: "Protanopia" },
	{ id: "deuteranopia", label: "Deuteranopia" },
	{ id: "tritanopia", label: "Tritanopia" },
] as const;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex,nofollow" />
		<title>Machines theme showcase</title>
	</head>
	<body style="margin: 0">
		<svg class="mx-cvd-filters" aria-hidden="true" focusable="false">
			<filter id="mx-cvd-protanopia" color-interpolation-filters="sRGB">
				<feColorMatrix type="matrix" values="0.567 0.433 0 0 0 0.558 0.442 0 0 0 0 0.242 0.758 0 0 0 0 0 1 0"></feColorMatrix>
			</filter>
			<filter id="mx-cvd-deuteranopia" color-interpolation-filters="sRGB">
				<feColorMatrix type="matrix" values="0.625 0.375 0 0 0 0.7 0.3 0 0 0 0 0.3 0.7 0 0 0 0 0 1 0"></feColorMatrix>
			</filter>
			<filter id="mx-cvd-tritanopia" color-interpolation-filters="sRGB">
				<feColorMatrix type="matrix" values="0.95 0.05 0 0 0 0 0.433 0.567 0 0 0 0.475 0.525 0 0 0 0 0 1 0"></feColorMatrix>
			</filter>
		</svg>
		<Root theme="warm">
			<header class="mx-header">
				<div class="mx-header__inner mx-shell">
					<a class="mx-brand" href="/__theme"><span class="mx-brand__mark"></span><span>MACHINES</span></a>
					<a class="mx-header-action" href="/">Back to Musi</a>
				</div>
				<NavTabs tabs={tabs} />
			</header>
			<Shell>
				<Panel title="Machines design system">
					<div class="mx-grid">
						<div class="mx-stack">
							<p class="mx-kicker">Old-style chrome / modern web</p>
							<h1>Reusable machine-era UI, rebuilt.</h1>
							<p>Visible controls, clear borders, soft gradients, dense structure, and modern access hooks.</p>
							<div class="mx-cluster">
								<Button href="#__controls">Controls</Button>
								<Button href="#__tabs" variant="secondary">Tabs</Button>
								<Button href="#__layout" variant="hollow">Layout</Button>
							</div>
						</div>
						<CodeFrame title="Install" language="ts" code={importExample} />
					</div>
				</Panel>

				<Section title="Package layers" kicker="Architecture">
					<div class="mx-grid">
						{componentGroups.map((group) => (
							<Tile title={group.name} kicker="Layer" action="Ready">
								<ul>{group.items.map((item) => <li>{item}</li>)}</ul>
							</Tile>
						))}
					</div>
				</Section>

				<Section id="__controls" title="Buttons and controls" kicker="Native + Astro">
					<div class="mx-stack">
						<Panel title="Button variants">
							<div class="mx-stack">
								<div class="mx-cluster">
									<Button>Primary</Button>
									<Button variant="secondary">Secondary</Button>
									<Button variant="hollow">Hollow</Button>
									<Button variant="ghost">Ghost</Button>
									<Button variant="danger">Danger</Button>
									<Button disabled>Disabled</Button>
								</div>
							</div>
						</Panel>
						<div class="mx-grid">
							<Card title="Form controls" kicker="Fields">
								<div class="mx-stack">
									<Field label="Text input"><input value="forum title" /></Field>
									<Field label="Select"><select><option>Docs</option><option>Install</option></select></Field>
									<Field label="Choice set">
										<div class="mx-cluster">
											<label><input type="checkbox" checked /> Dense rows</label>
											<label><input type="radio" name="demo-choice" checked /> Forum</label>
											<label><input type="radio" name="demo-choice" /> Article</label>
										</div>
									</Field>
									<Field label="Textarea"><textarea>Longer field content</textarea></Field>
								</div>
							</Card>
							<Card title="Compact controls" kicker="Actions">
								<div class="mx-cluster">
									<Button>Save</Button>
									<Button variant="secondary">Preview</Button>
									<Button variant="hollow">Tools</Button>
								</div>
							</Card>
							<Message title="Control guidance" mark="※"><p>Use filled buttons for final actions, hollow buttons for tools, and links for navigation.</p></Message>
						</div>
						<CodeFrame title="Button usage" language="astro" code={buttonExample} />
					</div>
				</Section>

				<Section id="__tabs" title="Tabs and code frames" kicker="Preact">
					<div class="mx-stack">
						<MachinesWidgets client:load />
						<CodeFrame title="CodeTabs usage" language="tsx" code={codeTabsExample} />
					</div>
				</Section>

				<Section id="__bars" title="Bars and lists" kicker="Native + wrappers">
					<div class="mx-stack">
						<div class="mx-grid">
							<Card title="Native bars" kicker="HTML">
								<div class="mx-stack">
									<Field label="Range"><input type="range" value="62" min="0" max="100" /></Field>
									<Field label="Progress"><progress value="72" max="100">72%</progress></Field>
									<Field label="Meter"><meter value="82" min="0" max="100" low="35" high="75" optimum="90">82</meter></Field>
								</div>
							</Card>
							<Card title="Machines bars" kicker="Astro">
								<div class="mx-stack">
									<ProgressBar label="Build progress" value={72} showValue={true} />
									<ProgressBar label="Warnings" value={38} tone="warning" showValue={true} />
									<MeterBar label="Cache health" value={82} high={75} optimum={90} showValue={true} />
									<p>Progress is smooth completion. Meter is segmented measurement with thresholds.</p>
								</div>
							</Card>
							<Card title="List variants" kicker="HTML">
								<div class="mx-grid">
									<List variant="check">
										<li>Native semantics</li>
										<li>Themed markers</li>
										<li>Accessible by default</li>
									</List>
									<List variant="menu">
										<li>Overview</li>
										<li>Controls</li>
										<li>Layout</li>
									</List>
								</div>
							</Card>
						</div>
						<CodeFrame title="Bars usage" language="astro" code={barsExample} />
					</div>
				</Section>

				<Section title="Messages" kicker="Status">
					<div class="mx-grid">
						<Message title="Message box" mark="※"><p>Use for hints, warnings, and status messages without one-use alert boxes.</p></Message>
						<CodeFrame title="Usage" language="astro" code={messageExample} />
					</div>
				</Section>

				<Section id="__layout" title="Layout and panels" kicker="Astro wrappers">
					<div class="mx-stack">
						<div class="mx-grid">
							<ActionCard href="#__controls" kicker="Start" title="Controls" description="Use native controls and Machines buttons for forms and actions." action="Inspect" tone="primary" />
							<ActionCard href="#__tabs" kicker="Enhance" title="Preact widgets" description="Add behavior only where static UI does not help." action="Run" />
							<ActionCard href="#__layout" kicker="Build" title="Astro wrappers" description="Use wrappers when structure repeats." action="Open" tone="quiet" />
						</div>
						<SidebarLayout title="Sidebar">
							<nav slot="sidebar" class="mx-sidebar__nav" aria-label="Showcase sections">
								<a class="mx-sidebar__link" href="#__controls">Controls</a>
								<a class="mx-sidebar__link" href="#__tabs">Tabs</a>
								<a class="mx-sidebar__link" href="#__layout" aria-current="page">Layout</a>
							</nav>
							<div slot="main">
								<div class="mx-sidebar-main__title">Main content header</div>
								<div class="mx-sidebar-main__body">Two-column layout keeps clear page clues without table layout.</div>
							</div>
						</SidebarLayout>
						<DataTable caption="Component status">
							<thead><tr><th>Layer</th><th>Status</th><th>Use</th></tr></thead>
							<tbody>
								<tr><td>Visual</td><td>Ready</td><td>Tokens, native elements, classes</td></tr>
								<tr><td>Astro</td><td>Ready</td><td>Static wrappers and shells</td></tr>
								<tr><td>Preact</td><td>Optional</td><td>Client enhancement widgets</td></tr>
							</tbody>
						</DataTable>
					</div>
				</Section>

				<Section title="Post layout" kicker="Conversation">
					<Post author="maintainer" meta="today"><p>Post layout supports forum-like talks, notes, changelog entries, and release comments.</p></Post>
				</Section>

				<Panel title="Theme color reference">
					<div class="mx-grid mx-token-compare" aria-label="Warm color token reference">
						<Root theme="warm" class="mx-token-scheme">
							<Card title="Warm / light" kicker="Reference">
								<div class="mx-stack">
									{colorTokens.map(([groupName, tokens]) => (
										<div class="mx-token-group">
											<div class="mx-token-group__title">{groupName}</div>
											<div class="mx-token-list">
												{tokens.map((token) => (
													<div class="mx-token-row">
														<span class="mx-token-swatch" style={`--mx-token-swatch-color: var(${token})`}></span>
														<span class="mx-token-name">{token}</span>
														<span class="mx-token-sample" style={`color: var(${token})`}>Sample</span>
													</div>
												))}
											</div>
										</div>
									))}
								</div>
							</Card>
						</Root>
					</div>
				</Panel>

				<Panel title="Color vision preview">
					<div class="mx-grid mx-cvd-grid" aria-label="Signal token previews for common color vision differences">
						{colorVisionPreviews.map((preview) => (
							<div class:list={["mx-cvd-preview", `mx-cvd-preview--${preview.id}`]}>
								<div class="mx-cvd-preview__title">{preview.label}</div>
								<div class="mx-cvd-preview__themes">
									<Root theme="warm" class="mx-token-scheme">
										<div class="mx-token-list">
											{signalTokens.map((token) => (
												<div class="mx-token-row mx-token-row--signal">
													<span class="mx-token-swatch" style={`--mx-token-swatch-color: var(${token})`}></span>
													<span class="mx-token-name">{token}</span>
													<span class="mx-token-sample" style={`color: var(${token})`}>Warm</span>
												</div>
											))}
										</div>
									</Root>
								</div>
							</div>
						))}
					</div>
				</Panel>

				<Panel title="Theme variants">
					<div class="mx-grid">
						<Root theme="warm"><Card title="Warm"><p>Warm brown and cream theme, good fit for Musi.</p></Card></Root>
						<Root theme="custom" style={customThemeStyle}><Card title="Custom"><p>Set CSS tokens on any Machines root without replacing components.</p></Card></Root>
					</div>
				</Panel>
			</Shell>
		</Root>
		<style>
			.mx-cvd-filters {
				position: absolute;
				width: 0;
				height: 0;
				overflow: hidden;
			}

			.mx-token-compare {
				align-items: start;
			}

			.mx-token-scheme {
				min-height: 100%;
			}

			.mx-token-group {
				display: grid;
				gap: 0.45rem;
				min-width: 0;
			}

			.mx-token-group__title {
				color: var(--mx-accent);
				font-size: 0.78rem;
				font-weight: 800;
				letter-spacing: 0.18em;
				text-transform: uppercase;
			}

			.mx-token-list {
				display: grid;
				border: 1px solid var(--mx-border);
				background: var(--mx-surface);
			}

			.mx-token-row {
				display: grid;
				grid-template-columns: 2.4rem minmax(8.5rem, 1fr) minmax(4.5rem, auto);
				gap: 0.7rem;
				align-items: center;
				min-width: 0;
				padding: 0.5rem 0.6rem;
				background: var(--mx-gradient-row);
			}

			.mx-token-row + .mx-token-row {
				border-top: 1px solid var(--mx-border-soft);
			}

			.mx-token-swatch {
				display: block;
				width: 2.1rem;
				height: 1.55rem;
				border: 1px solid var(--mx-border-strong);
				background: var(--mx-token-swatch-color);
				box-shadow: inset 1px 1px 0 color-mix(in srgb, var(--mx-bevel-highlight) 60%, transparent),
					inset -1px -1px 0 color-mix(in srgb, var(--mx-bevel-lowlight) 70%, transparent);
			}

			.mx-token-name {
				min-width: 0;
				font-family: var(--mx-font-mono);
				font-size: 0.86rem;
				overflow-wrap: anywhere;
			}

			.mx-token-sample {
				justify-self: end;
				max-width: 7rem;
				padding: 0.18rem 0.38rem;
				border: 1px solid var(--mx-border-soft);
				background: var(--mx-surface);
				font-weight: 800;
				overflow-wrap: anywhere;
			}

			.mx-cvd-grid {
				align-items: start;
			}

			.mx-cvd-preview {
				display: grid;
				gap: 0.55rem;
				min-width: 0;
				padding: 0.75rem;
				border: 1px solid var(--mx-border);
				background: var(--mx-gradient-panel);
			}

			.mx-cvd-preview--protanopia {
				filter: url("#mx-cvd-protanopia");
			}

			.mx-cvd-preview--deuteranopia {
				filter: url("#mx-cvd-deuteranopia");
			}

			.mx-cvd-preview--tritanopia {
				filter: url("#mx-cvd-tritanopia");
			}

			.mx-cvd-preview__title {
				color: var(--mx-accent);
				font-size: 0.82rem;
				font-weight: 900;
				letter-spacing: 0.16em;
				text-transform: uppercase;
			}

			.mx-cvd-preview__themes {
				display: grid;
				gap: 0.65rem;
			}

			.mx-token-row--signal {
				grid-template-columns: 2.4rem minmax(7rem, 1fr) minmax(3.8rem, auto);
			}

			@media (max-width: 42rem) {
				.mx-token-row {
					grid-template-columns: 2.4rem minmax(0, 1fr);
				}

				.mx-token-sample {
					grid-column: 2;
					justify-self: start;
				}
			}
		</style>
	</body>
</html>
