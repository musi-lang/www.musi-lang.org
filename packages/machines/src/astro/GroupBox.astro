---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	legend: string;
	variant?: "default" | "accent" | "compact";
	class?: string;
}
const {
	legend,
	variant = "default",
	class: className = "",
	...rest
} = Astro.props;
---
<section
	{...rest}
	class:list={[
		"mx-groupbox",
		variant !== "default" && `mx-groupbox--${variant}`,
		className,
	]}
>
	<div class="mx-groupbox__legend">{legend}</div>
	<div class="mx-groupbox__body"><slot /></div>
</section>
