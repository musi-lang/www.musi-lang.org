---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	title?: string;
	language?: string;
	code?: string;
	class?: string;
}
const { title, language, code, class: className = "", ...rest } = Astro.props;
---
<div {...rest} class:list={["mx-code-frame", className]}>
	{title || language ? (
		<div class="mx-code-frame__header">
			{title ? <span>{title}</span> : <span></span>}
			{language ? <span class="mx-code-frame__language">{language}</span> : null}
		</div>
	) : null}
	<pre><code>{code}<slot /></code></pre>
</div>
