---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	title?: string;
	class?: string;
}
const { title, class: className = "", ...rest } = Astro.props;
---
<div {...rest} class:list={["mx-sidebar-layout", className]}>
	<aside class="mx-sidebar">
		{title ? <div class="mx-sidebar__title">{title}</div> : null}
		<div class="mx-sidebar__body"><slot name="sidebar" /></div>
	</aside>
	<main class="mx-sidebar-main"><slot name="main" /></main>
</div>
