---
interface Props {
	label: string;
	hint?: string;
	class?: string;
}
// biome-ignore lint/correctness/noUnusedVariables: Astro template expressions consume these values.
const { label, hint, class: className = "", ...rest } = Astro.props;
---
<label {...rest} class:list={["mx-field", className]}>
	<span class="mx-field__label">{label}</span>
	<slot />
	{hint ? <span>{hint}</span> : null}
</label>
