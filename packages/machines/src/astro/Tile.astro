---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	title: string;
	kicker?: string;
	action?: string;
	href?: string;
	class?: string;
}
const {
	title,
	kicker,
	action,
	href,
	class: className = "",
	...rest
} = Astro.props;
const Tag = href ? "a" : "article";
---
<Tag {...rest} href={href} class:list={["mx-tile", className]}>
	<div class="mx-tile__head">
		{kicker ? <span class="mx-tile__kicker">{kicker}</span> : null}
		<span class="mx-tile__action">{action ?? (href ? "Open" : "")}</span>
	</div>
	<strong class="mx-tile__title">{title}</strong>
	<div class="mx-tile__body"><slot /></div>
</Tag>
