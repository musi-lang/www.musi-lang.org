---
interface Props {
	kicker?: string;
	title?: string;
	class?: string;
	id?: string;
}
// biome-ignore lint/correctness/noUnusedVariables: Astro template expressions consume these values.
const { kicker, title, class: className = "", ...rest } = Astro.props;
---
<section {...rest} class:list={["mx-section", className]}>
	{
		title ? (
			<div class="mx-section__title">
				{kicker ? <span>{kicker} · </span> : null}
				{title}
			</div>
		) : null
	}
	<div class="mx-section__body"><slot /></div>
</section>
