---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	tone?: "info" | "success" | "warning" | "danger";
	title?: string;
	mark?: string;
	class?: string;
}
const {
	tone = "info",
	title,
	mark = "※",
	class: className = "",
	...rest
} = Astro.props;
---
<aside {...rest} class:list={["mx-message", `mx-message--${tone}`, className]}>
	<div class="mx-message__mark" aria-hidden="true">{mark}</div>
	<div>
		{title ? <strong>{title}</strong> : null}
		<slot />
	</div>
</aside>
