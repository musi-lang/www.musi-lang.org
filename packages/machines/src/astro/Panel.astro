---
interface Props {
	title?: string;
	class?: string;
}
// biome-ignore lint/correctness/noUnusedVariables: Astro template expressions consume these values.
const { title, class: className = "", ...rest } = Astro.props;
---
<section {...rest} class:list={["mx-panel", className]}>
	{title ? <div class="mx-panel__title">{title}</div> : null}
	<div class="mx-panel__body"><slot /></div>
</section>
