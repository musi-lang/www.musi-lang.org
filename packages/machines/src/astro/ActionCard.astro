---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	href: string;
	title: string;
	kicker?: string;
	description?: string;
	action?: string;
	tone?: "primary" | "secondary" | "quiet";
	class?: string;
}
const {
	href,
	title,
	kicker,
	description,
	action = "Open",
	tone = "secondary",
	class: className = "",
	...rest
} = Astro.props;
---
<a
	{...rest}
	href={href}
	class:list={["mx-action-card", `mx-action-card--${tone}`, className]}
>
	<span class="mx-action-card__head">
		{kicker ? <span class="mx-action-card__kicker">{kicker}</span> : null}
		<span class="mx-action-card__action">{action}</span>
	</span>
	<strong class="mx-action-card__title">{title}</strong>
	{description ? <span class="mx-action-card__body">{description}</span> : null}
</a>
