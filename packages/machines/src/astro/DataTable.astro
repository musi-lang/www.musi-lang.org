---
interface Props {
	caption?: string;
	class?: string;
}
// biome-ignore lint/correctness/noUnusedVariables: Astro template expressions consume these values.
const { caption, class: className = "", ...rest } = Astro.props;
---
<div {...rest} class:list={["mx-table-wrap", className]}>
	<table>
		{caption ? <caption>{caption}</caption> : null}
		<slot />
	</table>
</div>
