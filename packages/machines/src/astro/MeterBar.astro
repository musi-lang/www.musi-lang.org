---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	label: string;
	value: number;
	min?: number;
	max?: number;
	low?: number;
	high?: number;
	optimum?: number;
	showValue?: boolean;
	class?: string;
}
const {
	label,
	value,
	min = 0,
	max = 100,
	low,
	high,
	optimum,
	showValue = false,
	class: className = "",
	...rest
} = Astro.props;
const safeMax = max > min ? max : min + 100;
const clampedValue = Math.min(Math.max(value, min), safeMax);
const percent = Math.round(((clampedValue - min) / (safeMax - min)) * 100);
const thresholdPercent = (threshold: number | undefined): number | undefined =>
	typeof threshold === "number"
		? Math.round(((Math.min(Math.max(threshold, min), safeMax) - min) / (safeMax - min)) * 100)
		: undefined;
const lowPercent = thresholdPercent(low);
const highPercent = thresholdPercent(high);
const optimumPercent = thresholdPercent(optimum);
const tone =
	typeof optimum === "number" && clampedValue >= optimum ? "success" :
	typeof high === "number" && clampedValue >= high ? "warning" :
	typeof low === "number" && clampedValue <= low ? "danger" :
	"accent";
const style = [
	`--mx-bar-value: ${percent}%`,
	lowPercent !== undefined && `--mx-meter-low: ${lowPercent}%`,
	highPercent !== undefined && `--mx-meter-high: ${highPercent}%`,
	optimumPercent !== undefined && `--mx-meter-optimum: ${optimumPercent}%`,
].filter(Boolean).join("; ");
---
<div
	{...rest}
	class:list={["mx-bar", "mx-bar--meter", tone !== "accent" && `mx-bar--${tone}`, className]}
	style={style}
	role="meter"
	aria-label={label}
	aria-valuemin={min}
	aria-valuemax={safeMax}
	aria-valuenow={clampedValue}
>
	<div class="mx-bar__head">
		<span class="mx-bar__label">{label}</span>
		{showValue ? <span class="mx-bar__value">{clampedValue}</span> : null}
	</div>
	<div class="mx-bar__track" aria-hidden="true">
		<div class="mx-bar__fill"></div>
	</div>
</div>
