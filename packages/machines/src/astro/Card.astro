---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	title?: string;
	kicker?: string;
	href?: string;
	variant?: "default" | "accent";
	class?: string;
}
const {
	title,
	kicker,
	href,
	variant = "default",
	class: className = "",
	...rest
} = Astro.props;
const Tag = href ? "a" : "article";
---
<Tag
	{...rest}
	href={href}
	class:list={["mx-card", variant === "accent" && "mx-card--accent", className]}
>
	{
		title ? (
			<div class="mx-card__title">
				{kicker ? <span>{kicker} · </span> : null}
				{title}
			</div>
		) : null
	}
	<div class="mx-card__body"><slot /></div>
</Tag>
