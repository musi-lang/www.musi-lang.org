---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	theme?: "warm" | "custom";
	class?: string;
}
const {
	theme = "warm",
	class: className = "",
	...rest
} = Astro.props;
---
<div
	{...rest}
	data-mx-root
	data-mx-theme={theme}
	class:list={["mx-root", className]}
>
	<slot />
</div>
