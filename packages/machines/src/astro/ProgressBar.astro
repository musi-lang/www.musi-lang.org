---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	label: string;
	value: number;
	max?: number;
	tone?: "accent" | "success" | "warning" | "danger";
	showValue?: boolean;
	class?: string;
}
const {
	label,
	value,
	max = 100,
	tone = "accent",
	showValue = false,
	class: className = "",
	...rest
} = Astro.props;
const safeMax = max > 0 ? max : 100;
const clampedValue = Math.min(Math.max(value, 0), safeMax);
const percent = Math.round((clampedValue / safeMax) * 100);
---
<div
	{...rest}
	class:list={["mx-bar", "mx-bar--progress", tone !== "accent" && `mx-bar--${tone}`, className]}
	style={`--mx-bar-value: ${percent}%`}
	role="progressbar"
	aria-label={label}
	aria-valuemin="0"
	aria-valuemax={safeMax}
	aria-valuenow={clampedValue}
>
	<div class="mx-bar__head">
		<span class="mx-bar__label">{label}</span>
		{showValue ? <span class="mx-bar__value">{percent}%</span> : null}
	</div>
	<div class="mx-bar__track" aria-hidden="true">
		<div class="mx-bar__fill"></div>
	</div>
</div>
