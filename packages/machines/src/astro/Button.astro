---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	href?: string;
	variant?: "primary" | "secondary" | "hollow" | "ghost" | "link" | "danger";
	type?: "button" | "submit" | "reset";
	disabled?: boolean;
	class?: string;
}
const {
	href,
	variant = "primary",
	type = "button",
	class: className = "",
	...rest
} = Astro.props;
const Tag = href ? "a" : "button";
---
<Tag
	{...rest}
	href={href}
	type={href ? undefined : type}
	class:list={["mx-button", `mx-button--${variant}`, className]}
>
	<slot />
</Tag>
