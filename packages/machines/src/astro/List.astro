---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template expressions consume frontmatter values.
interface Props {
	ordered?: boolean;
	variant?: "default" | "compact" | "ruled" | "check" | "menu";
	class?: string;
}
const {
	ordered = false,
	variant = "default",
	class: className = "",
	...rest
} = Astro.props;
const Tag = ordered ? "ol" : "ul";
---
<Tag
	{...rest}
	class:list={[
		"mx-list",
		variant !== "default" && `mx-list--${variant}`,
		className,
	]}
>
	<slot />
</Tag>
