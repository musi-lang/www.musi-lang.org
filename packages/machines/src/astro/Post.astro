---
interface Props {
	author?: string;
	meta?: string;
	class?: string;
}
// biome-ignore lint/correctness/noUnusedVariables: Astro template expressions consume these values.
const { author = "system", meta, class: className = "", ...rest } = Astro.props;
---
<article {...rest} class:list={["mx-post", className]}>
	<header class="mx-post__meta">
		{author}
		{meta ? <span> / {meta}</span> : null}
	</header>
	<div class="mx-post__body"><slot /></div>
</article>
