---
export interface NavTab {
	href: string;
	label: string;
	active?: boolean;
}
interface Props {
	tabs: NavTab[];
	label?: string;
	class?: string;
}
// biome-ignore lint/correctness/noUnusedVariables: Astro template expressions consume these values.
const { tabs, label = "Primary", class: className = "", ...rest } = Astro.props;
---
<nav {...rest} class:list={["mx-nav-rail", className]} aria-label={label}>
	<ul class="mx-nav-tabs">
		{
			tabs.map((tab) => (
				<li>
					<a
						class="mx-tab"
						href={tab.href}
						aria-current={tab.active ? "page" : undefined}
					>
						{tab.label}
					</a>
				</li>
			))
		}
	</ul>
</nav>
