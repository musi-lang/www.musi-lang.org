{
	"name": "www.musi-lang.org",
	"private": true,
	"packageManager": "bun@1.3.12",
	"workspaces": [
		"www",
		"packages/*"
	],
	"scripts": {
		"generate:content": "bun run --cwd www generate:content",
		"generate:content:check": "bun run --cwd www generate:content:check",
		"validate:language-docs": "bun run --cwd www validate:language-docs",
		"dev": "bun run --cwd www dev",
		"docs:studio": "bun run --cwd www docs:studio",
		"dev:prod": "bun run build:prod && bun run preview:prod",
		"build": "bun run --cwd www build",
		"build:prod": "bun run build",
		"verify:lang": "bun run --cwd www verify:lang",
		"check": "bun run generate:content && bun run typecheck && bun run biome:check",
		"test": "bun run generate:content && bun run test:run",
		"test:run": "bunx vitest run www/src",
		"typecheck": "bunx tsc -p www/tsconfig.json --noEmit",
		"preview": "bun run --cwd www preview",
		"preview:prod": "bun run --cwd www preview --host 0.0.0.0",
		"biome:check": "bun run --cwd www biome:check",
		"biome:format": "bun run --cwd www biome:format",
		"biome:lint": "bun run --cwd www biome:lint"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/bun": "1.3.12",
		"@types/node": "25.6.0",
		"bun-types": "1.3.12",
		"jsdom": "29.0.2",
		"typescript": "6.0.2",
		"vitest": "4.1.4"
	},
	"dependencies": {
		"ts-morph": "^28.0.0"
	},
	"author": {
		"name": "musi-lang"
	}
}
