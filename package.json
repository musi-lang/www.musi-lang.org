{
	"name": "www.musi-lang.org",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"sync:musi-grammar": "bun run scripts/sync-musi-grammar.ts",
		"sync:musi-grammar:check": "bun run scripts/sync-musi-grammar.ts --check",
		"generate:content": "bun run sync:musi-grammar && bun run scripts/generate-content.ts",
		"generate:content:check": "bun run sync:musi-grammar:check && bun run scripts/generate-content.ts --check",
		"dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
		"docs:studio": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 127.0.0.1 --port 4322",
		"dev:prod": "bun run build:prod && bun run preview:prod",
		"build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
		"build:prod": "bun run build",
		"check": "bun run generate:content && bun run typecheck && bun run biome:check",
		"test": "bun run generate:content && bun run test:run",
		"test:run": "bunx vitest run src",
		"typecheck": "bunx tsc -p tsconfig.json --noEmit",
		"preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
		"preview:prod": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0",
		"biome:check": "bunx biome check . --max-diagnostics 16384",
		"biome:format": "bunx biome format . --write --max-diagnostics 16384",
		"biome:lint": "bunx biome lint . --max-diagnostics 16384"
	},
	"dependencies": {
		"@astrojs/preact": "^5.1.2",
		"@musi-lang/machines": "workspace:*",
		"astro": "^6.1.9",
		"preact": "^10.29.1",
		"preact-render-to-string": "^6.6.7",
		"ts-morph": "^28.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@types/bun": "1.3.13",
		"@types/node": "25.6.0",
		"bun-types": "1.3.13",
		"jsdom": "29.0.2",
		"marked": "^18.0.2",
		"sass": "^1.99.0",
		"shiki": "^4.0.2",
		"typescript": "6.0.3",
		"vite": "^8.0.10",
		"vitest": "4.1.5",
		"wrangler": "^4.85.0"
	},
	"author": {
		"name": "musi-lang"
	}
}
